        color: #16a34a;
        font-size: 14px;
        margin: 0;
    }

    .error-msg {
        color: #ef4444;
        font-size: 14px;
        margin: 0;
    }

    .upcoming-card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
