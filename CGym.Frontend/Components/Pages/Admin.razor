            accent-color: #16a34a;
        }

    .time-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .clickable-card {
        cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s;
    }

        .clickable-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
        }

    .stat-hint {
        font-size: 12px;
        opacity: 0.75;
        margin-top: 4px;
    }

    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .modal-card {
        background: white;
        border-radius: 16px;
