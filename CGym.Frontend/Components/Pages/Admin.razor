@code {
    private string navn = "";
    private int kapacitet = 0;
    private string message = "";
    private bool success = false;
    private bool showCreateActivityForm = false;
    private bool showCreateTrainerFrom = false;
    private string trainerName = "";
    private string trainerMessage = "";
    private int? selectedTrainerActivityId; 
    private int? selectedTrainerId;
    private DateTime? startDatoTid;
    private string aktivitetDato = "";
    private string aktivitetTid = "";
    private int totalMedlemmer = 0;
    private int totalAktiviteter = 0;
    private int totalBookinger = 0;
    private bool showMemberModal = false;
    private bool isLoadingMembers = false;
    private List<CGym.Frontend.Models.Member> allMembers = new();
    private Dictionary<int, List<BookingApiModel>> memberBookings = new();
    private List<BookingApiModel> allBookings = new();
    private bool allBookingsLoaded = false;
    private bool showBookingModal = false;
    private string trainerEmail = "";
    private string trainerPhoneNumber = "";
    private string availableFrom = "";
    private string availableTo = "";

    private List<string> selectedWeekDays = new();

    private readonly List<string> weekDays = new()
    {
        "Mandag",
        "Tirsdag",
        "Onsdag",
        "Torsdag",
        "Fredag",
        "Lørdag",
        "Søndag"
    };

    private List<TrainerApiModel> trainers = new();
    private List<AktivitetItem> aktiviteter = new();
    private List<AktivitetItem> kommendeAktiviteter = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated || !AuthService.IsAdmin)
        {
            Nav.NavigateTo("/admin/login");
            return;
        }
        try
        {
            trainers = await TrainerService.GetTrainersAsync();

            var apiActivities = await ActivityService.GetActivitiesAsync();

            aktiviteter = apiActivities
                .Select(a => new AktivitetItem(
                    a.Id,
                    a.Name,
                    a.Trainer?.Name ?? "Ikke angivet",
                    a.StartTime,
                    a.StartTime.ToString("dd-MM-yyyy HH:mm"),
                    a.Capacity))
                .ToList();

            totalAktiviteter = aktiviteter.Count(a => a.StartTime >= DateTime.Now);

            kommendeAktiviteter = aktiviteter
                .Where(a => a.StartTime >= DateTime.Now)
                .OrderBy(a => a.StartTime)
                .Take(3)
                .ToList();
    
            var members = await MemberService.GetMembersAsync();
            totalMedlemmer = members?.Count ?? 0;
            allMembers = members ?? new();

            allBookings = await BookingService.GetBookingsAsync();
            allBookingsLoaded = true;
            totalBookinger = allBookings.Count(b => b.Activity?.StartTime >= DateTime.Now);

        }
        catch
        {
            success = false;
            message = "Kunne ikke hente data.";
        }

    }

    private async Task OpretAktivitet()
    {
        if (string.IsNullOrWhiteSpace(navn) ||
            string.IsNullOrWhiteSpace(aktivitetDato) ||
            string.IsNullOrWhiteSpace(aktivitetTid) ||
            kapacitet <= 0 || 
            !selectedTrainerId.HasValue)
        {
            success = false;
            message = "Udfyld alle felter korrekt.";
            return;
        }

        if (!DateTime.TryParseExact(
                $"{aktivitetDato} {aktivitetTid}",
                "dd-MM-yyyy HH:mm",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None,
                out var parsedStartDatoTid))
        {
            success = false;
            message = "Dato og tid skal skrives som f.eks. 28-04-2026 og 12:00.";
            return;
        }


        var request = new CreateActivityRequest
        {
            Name = navn.Trim(),
            StartTime = parsedStartDatoTid,
            Capacity = kapacitet,
            TrainerId = selectedTrainerId.Value
        }; 

        try
        {
            await ActivityService.CreateActivityAsync(request);
            totalAktiviteter++;
            success = true; 
            message = $"{navn} er oprettet!";
            navn = "";
            kapacitet = 0;
            selectedTrainerId = null;
            startDatoTid = null; 
            aktivitetDato = "";
            aktivitetTid = "";
        } catch
        {
            success = false; 
            message = "Kunne ikke oprette aktivitet via API.";
        }

    }

    private void ToggleWeekDay(string day, ChangeEventArgs e)
    {
        var isChecked = e.Value as bool? ?? false;

        if (isChecked)
        {
            if (!selectedWeekDays.Contains(day))
            {
                selectedWeekDays.Add(day);
            }
        }
        else
        {
            selectedWeekDays.Remove(day);
        }
    }

    private string BuildTrainerAvailability()
    {
        var days = string.Join(", ", selectedWeekDays);
        return $"{days} kl. {availableFrom}-{availableTo}";
    }


    private async Task OpretTraener()
    {
        if (string.IsNullOrWhiteSpace(trainerName))
        {
            trainerMessage = "skrive et trænernavn";
            return;
        }

        if (string.IsNullOrWhiteSpace(trainerEmail) ||
        string.IsNullOrWhiteSpace(trainerPhoneNumber) ||
        selectedWeekDays.Count == 0 ||
        string.IsNullOrWhiteSpace(availableFrom) ||
        string.IsNullOrWhiteSpace(availableTo))
        {
            trainerMessage = "Udfyld email, telefon og tilgængelighed.";
            return;
        }


        if (!selectedTrainerActivityId.HasValue)
        {
            trainerMessage = "vælg en aktivitet";
            return; 
        }

        try
        {
            var availability = BuildTrainerAvailability();

            var createTrainer = await TrainerService.CreateTrainerAsync(
                trainerName.Trim(),
                trainerEmail.Trim(),
                trainerPhoneNumber.Trim(),
                availability
            );

            if (createTrainer == null)
            {
                trainerMessage = "Træner blev ikke oprettet korrekt"; 
                return; 
            }
            trainers.Add(createTrainer);

            var selectedActivity = aktiviteter.FirstOrDefault(a => a.Id == selectedTrainerActivityId.Value);

            if (selectedActivity == null)
            {
                trainerMessage = "Den valgt aktivitet blev ikke fundet";
                return; 
            }

            var updateRequest = new CreateActivityRequest
                {
                    Name = selectedActivity.Navn,
                    StartTime = selectedActivity.StartTime,
                    Capacity = selectedActivity.Kapacitet,
                    TrainerId = createTrainer.Id
                };

            await ActivityService.UpdateActivityAsync(selectedActivity.Id, updateRequest);

            var index = aktiviteter.FindIndex(a => a.Id == selectedActivity.Id);

            if (index >= 0)
            {
                aktiviteter[index] = selectedActivity with
                    {
                        Trainer = createTrainer.Name
                    };
            }

                trainerMessage = $"{createTrainer.Name} er oprettet og koblet til {selectedActivity.Navn}.";
                trainerName = "";
                trainerEmail = "";
                trainerPhoneNumber = "";
                selectedWeekDays.Clear();
                availableFrom = "";
                availableTo = "";
                selectedTrainerActivityId = null;

        }
        catch
        {
            trainerMessage = "Kunne ikke oprette træner via API";
        }
    }

    private async Task SletAktivitet(AktivitetItem a)
    {
        try
        {
            await ActivityService.DeleteActivityAsync(a.Id);
            aktiviteter.Remove(a);
            totalAktiviteter = aktiviteter.Count(a => a.StartTime >= DateTime.Now);
            success = true;
            message = $"{a.Navn} er slettet.";
        }
        catch
        {
            success = false;
            message = "Kunne ikke slette aktivitet via API.";
        }
    }


    private async Task OpenMemberModal()
    {
        showMemberModal = true;
        await JS.InvokeVoidAsync("eval", "document.body.style.overflow='hidden'");

        if (memberBookings.Count == 0 && allMembers.Count > 0)
        {
            isLoadingMembers = true;
            StateHasChanged();

            try
            {
                if (!allBookingsLoaded)
                    allBookings = await BookingService.GetBookingsAsync();
                memberBookings = allBookings
                    .GroupBy(b => b.MemberId)
                    .ToDictionary(g => g.Key, g => g.ToList());
            }
            catch
            {
                memberBookings = new();
            }
            finally
            {
                isLoadingMembers = false;
            }
        }
    }

    private async Task CloseMemberModal()
    {
        showMemberModal = false;
        await JS.InvokeVoidAsync("eval", "document.body.style.overflow=''");
    }

    private async Task OpenBookingModal()
    {
        showBookingModal = true;
        await JS.InvokeVoidAsync("eval", "document.body.style.overflow='hidden'");
    }

    private async Task CloseBookingModal()
    {
        showBookingModal = false;
        await JS.InvokeVoidAsync("eval", "document.body.style.overflow=''");
    }

    private record AktivitetItem(int Id, string Navn, string Trainer,DateTime StartTime, string Tidspunkt, int Kapacitet);
}

