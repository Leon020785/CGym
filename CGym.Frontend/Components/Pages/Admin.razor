        border-radius: 8px;
        background: #2563eb;
        color: white;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-edit:hover {
            background: #1d4ed8;
        }

    .btn-delete {
        padding: 8px 12px;
        border: none;
        border-radius: 8px;
        background: #dc2626;
        color: white;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-delete:hover {
            background: #b91c1c;
        }

