        flex-direction: column;
        gap: 14px;
    }

    .upcoming-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .upcoming-header i {
        font-size: 24px;
        color: #16a34a;
    }

    .upcoming-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .upcoming-subtitle {
        font-size: 13px;
        color: #6b7280;
        margin: 4px 0 0 0;
    }

    .upcoming-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .upcoming-item {
        border-top: 4px solid #16a34a;
        background: #f9fafb;
        border-radius: 12px;
        padding: 14px;
        display: flex;
        justify-content: space-between;
        gap: 12px;
    }

    .upcoming-name {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
    }

    .upcoming-trainer {
        font-size: 13px;
        color: #6b7280;
        margin-top: 4px;
    }

    .upcoming-meta {
        display: flex;
        flex-direction: column;
        gap: 4px;
        font-size: 13px;
        color: #6b7280;
        text-align: right;
        white-space: nowrap;
    }

    .empty-upcoming {
        color: #6b7280;
        font-size: 14px;
        margin: 0;
    }


    .stat-card {
        border-radius: 14px;
        padding: 24px 20px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        color: white;
        min-height: 150px;
    }

    .stat-card.green {
        background: linear-gradient(135deg, #16a34a, #22c55e);
    }


    .stat-card.blue {
        background: linear-gradient(135deg, #3b82f6, #6366f1);
    }

    .stat-card.pink {
        background: linear-gradient(135deg, #a855f7, #ec4899);
    }

    .stat-icon {
        font-size: 22px;
    }

    .stat-number {
        font-size: 36px;
        font-weight: 700;
    }

    .stat-label {
        font-size: 13px;
        opacity: 0.9;
    }

    @@media (max-width: 768px) {
        .dashboard-top-grid {
            grid-template-columns: 1fr;
        }
    }

    .activity-list {
        background: white;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .list-title {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 4px 0;
    }

    .activity-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px;
        background: #f9fafb;
        border-radius: 10px;
    }

    .activity-name {
        font-size: 15px;
        font-weight: 600;
        color: #111827;
    }

    .activity-detail {
        font-size: 12px;
        color: #6b7280;
        margin-top: 4px;
    }

    .admin-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

