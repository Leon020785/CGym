@using CGym.Frontend.Services
@page "/admin"
@inject ActivityService ActivityService
@inject CGym.Frontend.Services.TrainerService TrainerService
@inject AuthService AuthService
@inject NavigationManager Nav
@inject MemberService MemberService
@inject BookingService BookingService
@inject IJSRuntime JS


<div class="admin-wrapper">
    <div class="page-header">
        
        <h2 class="page-title">Admin Panel</h2>
    </div>

    <!-- Hero banner -->
    <div class="hero-banner">
        <p class="hero-text">Her styrer du centerets hold og aktiviteter</p>
    </div>

    <div class="dashboard-top-grid">
        <div class="dashboard-left">
            <!-- Opret aktivitet -->
            <div class="create-card">
                <button type="button" class="create-header create-card-toggle" @onclick="() => showCreateActivityForm = !showCreateActivityForm">
                    <div class="create-icon">
                        <i class="ti ti-calendar-plus"></i>
                    </div>
                    <h3 class="create-title">Opret ny aktivitet</h3>
                    <span class="create-arrow">
                        <i class="@(showCreateActivityForm ? "ti ti-chevron-up" : "ti ti-chevron-down")"></i>
                    </span>
                </button>

                @if (showCreateActivityForm)
                {
                    <div class="form-group">
                        <label>Aktivitetsnavn</label>
                        <input @bind="navn" placeholder="f.eks. HIIT Training" class="input-field" />
                    </div>

                    <select @bind="selectedTrainerId" class="input-field">
                        <option value=""> Vælg en træner</option>
                        @foreach (var t in trainers)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }

                    </select>

                    <div class="time-grid">
                        <div class="form-group">
                            <label>Dato</label>
                            <input @bind="aktivitetDato" placeholder="28-04-2026" class="input-field" />
                        </div>

                        <div class="form-group">
                            <label>Kl.</label>
                            <input @bind="aktivitetTid" placeholder="12:00" class="input-field" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Kapacitet</label>
                        <input @bind="kapacitet" type="number" min="1" step="1" placeholder="f.eks. 15" class="input-field" />
                    </div>

                    @if (!string.IsNullOrEmpty(message))
                    {
                        <p class="@(success ? "success-msg" : "error-msg")">@message</p>
                    }

                    <button class="btn-opret" @onclick="OpretAktivitet">
                        Opret aktivitet
                    </button>
                }

                <button type="button" class="create-header create-card-toggle trainer-toggle" @onclick="() => showCreateTrainerFrom = !showCreateTrainerFrom">
                    <div class="create-icon">
                        <i class="ti ti-user-plus"></i>
                    </div>
                    <h3 class="create-title">Opret ny træner</h3>
                    <span class="create-arrow">
                        <i class="@(showCreateTrainerFrom ? "ti ti-chevron-up" : "ti ti-chevron-down")"></i>
                    </span>
                </button>

                @if (showCreateTrainerFrom)
                {
                    <div class="form-group">
                        <label>Trænernavn</label>
                        <input @bind="trainerName" placeholder="f.eks. Hans Hansen" class="input-field" />
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input @bind="trainerEmail" type="email" placeholder="f.eks. hans@cgym.dk" class="input-field" />
                    </div>

                    <div class="form-group">
                        <label>Telefon</label>
                        <input @bind="trainerPhoneNumber" type="tel" placeholder="f.eks. 12 34 56 78" class="input-field" />
                    </div>

                    <div class="form-group">
                        <label>Tilgængelige dage</label>

                        <div class="weekday-grid">
                            @foreach (var day in weekDays)
                            {
                                <label class="weekday-option">
                                    <input type="checkbox"
                                           checked="@selectedWeekDays.Contains(day)"
                                           @onchange="e => ToggleWeekDay(day, e)" />
                                    <span>@day</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="time-grid">
                        <div class="form-group">
                            <label>Fra kl.</label>
                            <input @bind="availableFrom" placeholder="12:00" class="input-field" />
                        </div>

                        <div class="form-group">
                            <label>Til kl.</label>
                            <input @bind="availableTo" placeholder="20:00" class="input-field" />
                        </div>
                    </div>

                    <select @bind="selectedTrainerActivityId" class="input-field">
                        <option value="">vælg aktivitet</option>
                        @foreach (var a in aktiviteter)
                        {
                            <option value="@a.Id">@a.Navn - @a.Tidspunkt</option>
                        }
                    </select>

                    @if (!string.IsNullOrEmpty(trainerMessage))
                    {
                        <p class="success-msg">@trainerMessage</p>
                    }

                    <button class="btn-opret" @onclick="OpretTraener">
                        Opret træner
                    </button>
                }

            </div>

            <div class="stat-card green clickable-card" @onclick="OpenMemberModal" 
                        role="button" tabindex="0" @onkeydown="@(async e => 
                        { if (e.Key == "Enter" || e.Key == " ") await OpenMemberModal(); })">
                <span class="stat-icon"><i class="ti ti-user"></i></span>
                <div class="stat-number">@totalMedlemmer</div>
                <div class="stat-label">Totale medlemmer</div>
                <div class="stat-hint">Klik for at se liste</div>
            </div>
        </div>

        <div class="dashboard-right">
            <div class="stat-card blue clickable-card" @onclick='() => Nav.NavigateTo("/admin/aktiviteter")' 
                    role="button" tabindex="0" @onkeydown="@(e => { if (e.Key == "Enter" || 
                    e.Key == " ") Nav.NavigateTo("/admin/aktiviteter"); })" style="cursor:pointer">
                <span class="stat-icon"><i class="ti ti-trending-up"></i></span>
                <div class="stat-number">@totalAktiviteter</div>
                <div class="stat-label">Totale aktiviteter</div>
                <div class="stat-hint">Klik for at se liste</div>
            </div>

            <div class="stat-card pink clickable-card" @onclick="OpenBookingModal" 
                    role="button" tabindex="0" @onkeydown="@(async e => { if (e.Key == "Enter" ||
                    e.Key == " ") await OpenBookingModal(); })">
                <span class="stat-icon"><i class="ti ti-calendar-plus"></i></span>
                <div class="stat-number">@totalBookinger</div>
                <div class="stat-label">Totale bookinger</div>
                <div class="stat-hint">Klik for at se liste</div>
            </div>
        </div>
    </div>

    @if (showMemberModal)
    {
        <div class="modal-backdrop" @onclick="CloseMemberModal">
            <div class="modal-card" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <div>
                        <h3 class="modal-title">Medlemsliste</h3>
                        <p class="modal-subtitle">@(totalMedlemmer == 1 ? "1 aktivt medlem" : $"{totalMedlemmer} aktive medlemmer")</p>
                    </div>
                    <button class="modal-close" @onclick="CloseMemberModal">✕</button>
                </div>

                @if (isLoadingMembers)
                {
                    <p class="modal-empty">Henter medlemmer...</p>
                }
                else if (allMembers.Count == 0)
                {
                    <p class="modal-empty">Ingen medlemmer fundet.</p>
                }
                else
                {
                    <div class="member-list">
                        @foreach (var member in allMembers)
                        {
                            var upcomingBookings = memberBookings.GetValueOrDefault(member.Id, new())
                                    .Where(b => b.Activity?.StartTime >= DateTime.Now)
                                    .ToList();
                            <div class="member-item">
                                <div class="member-info">
                                    <div class="member-name">@member.FirstName @member.LastName</div>
                                    <div class="member-email">@member.Email</div>
                                    <div class="member-phone">@(string.IsNullOrWhiteSpace(member.PhoneNumber) ? "Ikke oplyst" : member.PhoneNumber)</div>
                                </div>
                                <div class="member-bookings">
                                    @if (upcomingBookings.Count == 0)
                                    {
                                        <span class="booking-empty">Ingen kommende bookinger</span>
                                    }
                                    else
                                    {
                                        @foreach (var b in upcomingBookings)
                                        {
                                            <span class="booking-tag">
                                                <i class="ti ti-calendar"></i>
                                                @b.Activity?.Name — @b.Activity?.StartTime.ToString("dd-MM-yyyy HH:mm")
                                            </span>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (showBookingModal)
    {
        var upcomingAll = allBookings
            .Where(b => b.Activity?.StartTime >= DateTime.Now)
            .OrderBy(b => b.Activity?.StartTime)
            .ToList();

        <div class="modal-backdrop" @onclick="CloseBookingModal">
            <div class="modal-card" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <div>
                        <h3 class="modal-title">Kommende bookinger</h3>
                        <p class="modal-subtitle">@(upcomingAll.Count == 1 ? "1 booking" : $"{upcomingAll.Count} bookinger")</p>
                    </div>
                    <button class="modal-close" @onclick="CloseBookingModal">✕</button>
                </div>

                @if (upcomingAll.Count == 0)
                {
                    <p class="modal-empty">Ingen kommende bookinger.</p>
                }
                else
                {
                    var membersById = allMembers.ToDictionary(m => m.Id);
                    <div class="member-list">
                        @foreach (var b in upcomingAll)
                        {
                            membersById.TryGetValue(b.MemberId, out var bMember);
                            <div class="member-item">
                                <div class="member-info">
                                    <div class="member-name">@(b.Activity?.Name ?? "Ukendt aktivitet")</div>
                                    <div class="member-email"><i class="ti ti-clock"></i> @b.Activity?.StartTime.ToString("dd-MM-yyyy HH:mm")</div>
                                </div>
                                <div class="member-info" style="text-align:right;">
                                    <div class="member-name">@(bMember != null ? $"{bMember.FirstName} {bMember.LastName}" : "Ukendt")</div>
                                    <div class="member-email">@(bMember?.Email ?? "")</div>
                                    <div class="member-phone">@(string.IsNullOrWhiteSpace(bMember?.PhoneNumber) ? "Ikke oplyst" : bMember!.PhoneNumber)</div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <div class="upcoming-card">
        <div class="upcoming-header">
            <div>
                <h3 class="upcoming-title">Kommende aktiviteter</h3>
                <p class="upcoming-subtitle">De næste 3 planlagte hold</p>
            </div>
            <i class="ti ti-calendar-event"></i>
        </div>

        @if (kommendeAktiviteter.Count == 0)
        {
            <p class="empty-upcoming">Ingen kommende aktiviteter.</p>
        }
        else
        {
            <div class="upcoming-list">
                @foreach (var aktivitet in kommendeAktiviteter)
                {
                    <div class="upcoming-item">
                        <div>
                            <div class="upcoming-name">@aktivitet.Navn</div>
                            <div class="upcoming-trainer">
                                <i class="ti ti-user"></i> @aktivitet.Trainer
                            </div>
                        </div>

                        <div class="upcoming-meta">
                            <span><i class="ti ti-clock"></i> @aktivitet.Tidspunkt</span>
                            <span><i class="ti ti-users"></i> @aktivitet.Kapacitet pladser</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>


</div>

<style>
    .admin-wrapper {
        padding: 24px 16px;
        max-width: 900px;
        margin: 0 auto;
        font-family: 'Segoe UI', sans-serif;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .back-btn {
        font-size: 20px;
        color: #111827;
        text-decoration: none;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .hero-banner {
        background-image: url("https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1200&q=80");
        background-size: cover;
        background-position: center 55%;
        background-repeat: no-repeat;
        border-radius: 16px;
        padding: 40px 24px;
        min-height: 200px;
        display: flex;
        align-items: flex-end;
    }

    .hero-text {
        color: white;
        font-size: 16px;
        font-weight: 500;
        margin: 0;
        text-shadow: 0 2px 8px rgba(0,0,0,0.75);
    }

    .dashboard-top-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        align-items: stretch;
    }

    .dashboard-left,
    .dashboard-right {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .dashboard-left > .create-card,
    .dashboard-left > .stat-card,
    .dashboard-right > .stat-card {
        box-sizing: border-box;
        min-height: 200px;
    }

    .dashboard-right > .stat-card {
        flex: none;
    }


    .create-card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .create-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 4px;
    }

    /*This makes the header look like part of the card*/ 
    .create-card-toggle {
        width: 100%;
        background: #16a34a;
        color: white;
        border: 0;
        outline: none;
        border-radius: 10px;
        padding: 14px;
