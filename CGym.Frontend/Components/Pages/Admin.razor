        }

    .modal-empty {
        color: #6b7280;
        font-size: 14px;
        margin: 0;
    }

    .member-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .member-item {
        background: #f9fafb;
        border-radius: 12px;
        padding: 14px 16px;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
    }

    .member-info {
        flex: 0 0 40%;
        min-width: 0;
    }

    .member-name {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
    }

    .member-email {
        font-size: 13px;
        color: #6b7280;
        margin-top: 2px;
    }

    .member-bookings {
        flex: 0 0 60%;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: flex-start;
    }

    .booking-tag {
        font-size: 12px;
        color: #374151;
        background: #e8f5e9;
        border-radius: 6px;
        padding: 4px 8px;
        white-space: normal;
