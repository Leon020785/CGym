@page "/reset-password"
@page "/admin/reset-password"
@inject CGym.Frontend.Services.AuthService AuthService
@inject NavigationManager Nav

<div class="login-wrapper @(isAdmin ? "admin-theme" : "")">
    <div class="login-card">
        <div class="logo-icon">
            @if (isAdmin)
            {
                <i class="ti ti-shield-lock" style="font-size:40px; color:white;"></i>
            }
            else
            {
                <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="28" cy="28" r="26" stroke="white" stroke-width="2" fill="none" />
                    <circle cx="28" cy="28" r="20" stroke="white" stroke-width="1" fill="none" />
                    <circle cx="28" cy="16" r="3" fill="white" />
                    <path d="M22 20 Q28 19 34 20 L32 30 H24 Z" fill="white" />
                    <path d="M22 20 L16 24 Q14 26 16 28 L20 26 L22 24" fill="white" />
                    <path d="M34 20 L40 24 Q42 26 40 28 L36 26 L34 24" fill="white" />
                    <path d="M24 30 L22 40 L26 40 L28 34 L30 40 L34 40 L32 30" fill="white" />
                    <path id="topArc" d="M 10,28 A 18,18 0 0,1 46,28" fill="none" />
                    <text font-size="5" fill="white" font-family="serif" font-weight="bold" letter-spacing="1">
                        <textPath href="#topArc" startOffset="10%">— CGYM FITNESS —</textPath>
                    </text>
                    <path id="bottomArc" d="M 10,28 A 18,18 0 0,0 46,28" fill="none" />
                    <text font-size="4.5" fill="white" font-family="serif" letter-spacing="1">
                        <textPath href="#bottomArc" startOffset="15%">SINCE 2025</textPath>
                    </text>
                </svg>
            }
        </div>

        <h1 class="brand">@(isAdmin ? "Admin" : "CGym")</h1>
        <p class="subtitle">Vælg ny adgangskode</p>

        @if (done)
        {
            <p class="success-msg">Din adgangskode er nulstillet!</p>
            <p class="back-link"><a href="@(isAdmin ? "/admin/login" : "/login")">Gå til login</a></p>
        }
        else if (string.IsNullOrEmpty(token))
        {
            <p class="error-msg">Ugyldigt nulstillingslink.</p>
            <p class="back-link"><a href="@(isAdmin ? "/admin/forgot-password" : "/forgot-password")">Prøv igen</a></p>
        }
        else
        {
            <div class="form-group">
                <label>Ny adgangskode</label>
                <div class="pwd-wrapper">
                    <input @bind="newPassword" type="@(showNew ? "text" : "password")" placeholder="••••••••" class="input-field" />
                    <button type="button" class="eye-btn" @onclick="() => showNew = !showNew" tabindex="-1">
                        @if (showNew)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        }
                    </button>
                </div>
            </div>

            <ul class="pwd-rules">
                <li class="@(newPassword.Length >= 8 ? "ok" : "")">Mindst 8 tegn</li>
                <li class="@(newPassword.Any(char.IsUpper) ? "ok" : "")">Mindst ét stort bogstav</li>
                <li class="@(newPassword.Any(char.IsDigit) ? "ok" : "")">Mindst ét tal</li>
            </ul>

            <div class="form-group">
                <label>Bekræft adgangskode</label>
                <div class="pwd-wrapper">
                    <input @bind="confirmPassword" type="@(showConfirm ? "text" : "password")" placeholder="••••••••" class="input-field" />
                    <button type="button" class="eye-btn" @onclick="() => showConfirm = !showConfirm" tabindex="-1">
                        @if (showConfirm)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        }
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(message))
            {
                <p class="error-msg">@message</p>
            }

            <button @onclick="HandleSubmit" class="btn-login" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Gemmer...</span>
                }
                else
                {
                    <span>Nulstil adgangskode</span>
                }
            </button>

            <p class="back-link"><a href="@(isAdmin ? "/admin/login" : "/login")">Tilbage til login</a></p>
        }
    </div>
</div>

<style>
    .login-wrapper {
        height: calc(100vh - 60px);
        width: 100%;
        overflow: hidden;
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 50%, #bbf7d0 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .login-card {
        background: white;
        border-radius: 20px;
        padding: clamp(16px, 3vh, 48px) clamp(16px, 3vw, 40px);
        width: 90%;
        max-width: 420px;
        max-height: 95vh;
        margin: 16px 0;
        box-shadow: 0 8px 40px rgba(0,0,0,0.10);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: clamp(4px, 1vh, 8px);
        overflow-y: auto;
    }

    .logo-icon {
        background: #16a34a;
        border-radius: 16px;
        width: 90px;
        height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 4px;
    }

    .brand {
        font-size: 28px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .subtitle {
        color: #6b7280;
        font-size: 15px;
        margin: 0 0 8px 0;
    }

    .form-group {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 6px;
    }

        .form-group label {
            font-size: 14px;
            font-weight: 500;
            color: #374151;
        }

    .pwd-wrapper {
        position: relative;
        width: 100%;
    }

    .input-field {
        width: 100%;
        padding: 12px 44px 12px 16px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

        .input-field:focus {
            border-color: #16a34a;
        }

    .eye-btn {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
    }

    .pwd-rules {
        list-style: none;
        padding: 0;
        margin: 0;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

        .pwd-rules li {
            font-size: 11px;
            color: #9ca3af;
            padding-left: 16px;
            position: relative;
        }

            .pwd-rules li::before {
                content: '✗';
                position: absolute;
                left: 0;
                color: #ef4444;
            }

            .pwd-rules li.ok {
                color: #16a34a;
            }

                .pwd-rules li.ok::before {
                    content: '✓';
                    color: #16a34a;
                }

    .btn-login {
        width: 100%;
        padding: 14px;
        background: #16a34a;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.2s;
    }

        .btn-login:hover {
            background: #15803d;
        }

        .btn-login:disabled {
            background: #86efac;
            cursor: not-allowed;
        }

    .error-msg {
        color: #dc2626;
        font-size: 14px;
        margin: 0;
    }

    .success-msg {
        color: #16a34a;
        font-size: 14px;
        font-weight: 500;
        text-align: center;
        margin: 0;
    }

    .back-link {
        font-size: 13px;
        color: #6b7280;
        margin-top: 4px;
    }

        .back-link a {
            color: #16a34a;
            text-decoration: none;
        }

            .back-link a:hover {
                text-decoration: underline;
            }

    /* Admin blue theme overrides */
    .admin-theme {
        background: linear-gradient(135deg, #1e3a5f 0%, #1e40af 50%, #1d4ed8 100%);
    }

    .admin-theme .login-card {
        box-shadow: 0 8px 40px rgba(0,0,0,0.20);
    }

    .admin-theme .logo-icon {
        background: #1d4ed8;
    }

    .admin-theme .input-field:focus {
        border-color: #1d4ed8;
    }

    .admin-theme .btn-login {
        background: #1d4ed8;
    }

    .admin-theme .btn-login:hover {
        background: #1e40af;
    }

    .admin-theme .btn-login:disabled {
        background: #93c5fd;
    }

    .admin-theme .back-link a {
        color: #1d4ed8;
    }

    @@media (max-width: 480px) {
        .login-card {
            padding: 24px 16px;
        }
    }
</style>

@code {
    private bool isAdmin => Nav.Uri.Contains("/admin/");

    [SupplyParameterFromQuery]
    private string? Token { get; set; }

    private string token => Token ?? "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string message = "";
    private bool isLoading = false;
    private bool done = false;
    private bool showNew = false;
    private bool showConfirm = false;

    private bool PasswordValid =>
        newPassword.Length >= 8 &&
        newPassword.Any(char.IsUpper) &&
        newPassword.Any(char.IsDigit);

    private async Task HandleSubmit()
    {
        message = "";

        if (!PasswordValid)
        {
            message = "Adgangskoden opfylder ikke kravene.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            message = "Adgangskoderne stemmer ikke overens.";
            return;
        }

        isLoading = true;

        try
        {
            var result = await AuthService.ResetPasswordAsync(token, newPassword);
            if (result.Succeeded)
                done = true;
            else
                message = result.ErrorMessage ?? "Noget gik galt. Prøv igen.";
        }
        catch
        {
            message = "Der skete en fejl. Prøv igen.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
