@page "/forgot-password"
@page "/admin/forgot-password"
@inject CGym.Frontend.Services.AuthService AuthService
@inject NavigationManager Nav

<div class="login-wrapper @(isAdmin ? "admin-theme" : "")">
    <div class="login-card">
        <div class="logo-icon">
            @if (isAdmin)
            {
                <i class="ti ti-shield-lock" style="font-size:40px; color:white;"></i>
            }
            else
            {
                <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="28" cy="28" r="26" stroke="white" stroke-width="2" fill="none" />
                    <circle cx="28" cy="28" r="20" stroke="white" stroke-width="1" fill="none" />
                    <circle cx="28" cy="16" r="3" fill="white" />
                    <path d="M22 20 Q28 19 34 20 L32 30 H24 Z" fill="white" />
                    <path d="M22 20 L16 24 Q14 26 16 28 L20 26 L22 24" fill="white" />
                    <path d="M34 20 L40 24 Q42 26 40 28 L36 26 L34 24" fill="white" />
                    <path d="M24 30 L22 40 L26 40 L28 34 L30 40 L34 40 L32 30" fill="white" />
                    <path id="topArc" d="M 10,28 A 18,18 0 0,1 46,28" fill="none" />
                    <text font-size="5" fill="white" font-family="serif" font-weight="bold" letter-spacing="1">
                        <textPath href="#topArc" startOffset="10%">— CGYM FITNESS —</textPath>
                    </text>
                    <path id="bottomArc" d="M 10,28 A 18,18 0 0,0 46,28" fill="none" />
                    <text font-size="4.5" fill="white" font-family="serif" letter-spacing="1">
                        <textPath href="#bottomArc" startOffset="15%">SINCE 2025</textPath>
                    </text>
                </svg>
            }
        </div>

        <h1 class="brand">@(isAdmin ? "Admin" : "CGym")</h1>
        <p class="subtitle">Nulstil din adgangskode</p>

        @if (sent)
        {
            <p class="success-msg">Tjek din email for et nulstillingslink.</p>
            <p class="back-link"><a href="@(isAdmin ? "/admin/login" : "/login")">Tilbage til login</a></p>
        }
        else
        {
            <div class="form-group">
                <label>Email</label>
                <input @bind="email" type="email" placeholder="din.email@eksempel.dk" class="input-field" />
            </div>

            @if (!string.IsNullOrEmpty(message))
            {
                <p class="error-msg">@message</p>
            }

            <button @onclick="HandleSubmit" class="btn-login" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Sender...</span>
                }
                else
                {
                    <span>Send nulstillingslink</span>
                }
            </button>

            <p class="back-link"><a href="@(isAdmin ? "/admin/login" : "/login")">Tilbage til login</a></p>
        }
    </div>
</div>

<style>
    .login-wrapper {
        height: calc(100vh - 60px);
        width: 100%;
        overflow: hidden;
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 50%, #bbf7d0 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .login-card {
        background: white;
        border-radius: 20px;
        padding: clamp(16px, 3vh, 48px) clamp(16px, 3vw, 40px);
        width: 90%;
        max-width: 420px;
        max-height: 95vh;
        margin: 16px 0;
        box-shadow: 0 8px 40px rgba(0,0,0,0.10);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: clamp(4px, 1vh, 8px);
    }

    .logo-icon {
        background: #16a34a;
        border-radius: 16px;
        width: 90px;
        height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 4px;
    }

    .brand {
        font-size: 28px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .subtitle {
        color: #6b7280;
        font-size: 15px;
        margin: 0 0 8px 0;
    }

    .form-group {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 8px;
    }

        .form-group label {
            font-size: 14px;
            font-weight: 500;
            color: #374151;
        }

    .input-field {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

        .input-field:focus {
            border-color: #16a34a;
        }

    .btn-login {
        width: 100%;
        padding: 14px;
        background: #16a34a;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.2s;
    }

        .btn-login:hover {
            background: #15803d;
        }

        .btn-login:disabled {
            background: #86efac;
            cursor: not-allowed;
        }

    .error-msg {
        color: #dc2626;
        font-size: 14px;
        margin: 0;
    }

    .success-msg {
        color: #16a34a;
        font-size: 14px;
        font-weight: 500;
        text-align: center;
        margin: 0;
    }

    .back-link {
        font-size: 13px;
        color: #6b7280;
        margin-top: 4px;
    }

        .back-link a {
            color: #16a34a;
            text-decoration: none;
        }

            .back-link a:hover {
                text-decoration: underline;
            }

    /* Admin blue theme overrides */
    .admin-theme {
        background: linear-gradient(135deg, #1e3a5f 0%, #1e40af 50%, #1d4ed8 100%);
    }

    .admin-theme .login-card {
        box-shadow: 0 8px 40px rgba(0,0,0,0.20);
    }

    .admin-theme .logo-icon {
        background: #1d4ed8;
    }

    .admin-theme .input-field:focus {
        border-color: #1d4ed8;
    }

    .admin-theme .btn-login {
        background: #1d4ed8;
    }

    .admin-theme .btn-login:hover {
        background: #1e40af;
    }

    .admin-theme .btn-login:disabled {
        background: #93c5fd;
    }

    .admin-theme .back-link a {
        color: #1d4ed8;
    }

    @@media (max-width: 480px) {
        .login-card {
            padding: 24px 16px;
        }
    }
</style>

@code {
    private bool isAdmin => Nav.Uri.Contains("/admin/");

    private string email = "";
    private string message = "";
    private bool isLoading = false;
    private bool sent = false;

    private async Task HandleSubmit()
    {
        isLoading = true;
        message = "";

        try
        {
            var result = await AuthService.ForgotPasswordAsync(email);
            if (result.Succeeded)
                sent = true;
            else
                message = result.ErrorMessage ?? "Noget gik galt. Prøv igen.";
        }
        catch
        {
            message = "Der skete en fejl. Prøv igen.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
