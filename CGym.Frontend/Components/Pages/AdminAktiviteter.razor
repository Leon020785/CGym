@page "/admin/aktiviteter"
@rendermode InteractiveServer
@inject CGym.Frontend.Services.ActivityService ActivityService

<div class="aktiviteter-wrapper">
    <div class="page-header">
        <h2 class="page-title">Aktiviteter</h2>
    </div>
    <p class="page-sub">Administrer centerets aktiviteter</p>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <p style="color:#dc2626; font-size:14px;">@loadError</p>
    }

    <div class="activity-list">
        @foreach (var activity in activities)
        {
            <div class="activity-card" style="border-top: 4px solid @activity.Color">
                <div class="activity-top">
                    <div>
                        <div class="activity-name">@activity.Name</div>
                        <div class="activity-instructor"><i class="ti ti-user"></i> @activity.Instructor</div>
                    </div>
                    <div class="activity-spots" style="color: @activity.Color">
                        @activity.SpotsLeft pladser
                    </div>
                </div>

                <div class="activity-info">
                    <span><i class="ti ti-calendar"></i> @activity.Date</span>
                    <span><i class="ti ti-clock"></i> @activity.Time</span>
                    <span><i class="ti ti-users"></i> @activity.Enrolled/@activity.Capacity</span>
                </div>

                <div class="admin-actions">
                    <button class="btn-edit" type="button" @onclick="() => StartRedigering(activity)">Rediger</button>
                    <button class="btn-delete" @onclick="() => SletAktivitet(activity)">Slet aktivitet</button>
                </div>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast @(showToast ? "show" : "")">
            <i class="ti @toastIcon"></i> @message
        </div>
    }
</div>

<style>
    .aktiviteter-wrapper {
        padding: 24px 16px;
        max-width: 800px;
        margin: 0 auto;
        font-family: 'Segoe UI', sans-serif;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 4px;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .page-sub {
        color: #6b7280;
        font-size: 14px;
        margin: 0 0 20px 0;
    }

    .activity-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .activity-card {
        background: white;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .activity-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .activity-name {
        font-size: 17px;
        font-weight: 700;
        color: #111827;
    }

    .activity-instructor {
        font-size: 13px;
        color: #6b7280;
        margin-top: 4px;
    }

    .activity-spots {
        font-size: 13px;
        font-weight: 600;
    }

    .activity-info {
        display: flex;
        gap: 16px;
        font-size: 13px;
        color: #6b7280;
    }

    .admin-actions {
        display: flex;
        gap: 10px;
        margin-top: 6px;
    }

    .btn-edit,
    .btn-delete {
        flex: 1;
        padding: 14px;
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        color: white;
        transition: background 0.2s;
    }

    .btn-edit {
        background: #2563eb;
    }

        .btn-edit:hover {
            background: #1d4ed8;
        }

    .btn-delete {
        background: #dc2626;
    }

        .btn-delete:hover {
            background: #b91c1c;
        }

    .toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #111827;
        color: white;
        padding: 12px 24px;
        border-radius: 10px;
        font-size: 14px;
        opacity: 0;
        transition: all 0.3s;
        pointer-events: none;
    }

        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }
</style>

@code {
    private string message = "";
    private string toastIcon = "ti-alert-triangle";
    private bool showToast = false;
    private string? loadError;
    private List<ActivityItem> activities = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loadError = null;

            var apiActivities = await ActivityService.GetActivitiesAsync();

            activities = apiActivities
                .Select(a => new ActivityItem(
                    a.Id,
                    a.Name,
                    a.Trainer?.Name ?? "Ikke angivet",
                    a.StartTime.ToString("dd-MM-yyyy"),
                    a.StartTime.ToString("HH:mm"),
                    a.Capacity,
                    0,
                    "#16a34a"))
                .ToList();
        }
        catch (HttpRequestException)
        {
            loadError = "Kunne ikke hente aktiviteter lige nu.";
            activities = new();
        }
        catch
        {
            loadError = "Der skete en uventet fejl ved indlæsning af aktiviteter.";
            activities = new();
        }
    }

    private async Task SletAktivitet(ActivityItem activity)
    {
        try
        {
            await ActivityService.DeleteActivityAsync(activity.Id);
            activities.Remove(activity);

            toastIcon = "ti-circle-check";
            message = $"{activity.Name} er slettet.";
        }
        catch
        {
            toastIcon = "ti-alert-triangle";
            message = "Kunne ikke slette aktivitet lige nu.";
        }

        showToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        showToast = false;
        message = "";
        StateHasChanged();
    }

    private void StartRedigering(ActivityItem activity)
    {
        toastIcon = "ti-circle-check";
        message = $"Du redigerer nu: {activity.Name}";
        showToast = true;
    }


    private record ActivityItem(int Id, string Name, string Instructor, string Date, string Time, int Capacity, int Enrolled, string Color)
    {
        public int SpotsLeft => Capacity - Enrolled;
    }
}
