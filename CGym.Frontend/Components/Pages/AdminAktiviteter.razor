@page "/admin/aktiviteter"
@inject CGym.Frontend.Services.ActivityService ActivityService
@inject CGym.Frontend.Services.TrainerService TrainerService
@inject CGym.Frontend.Services.AuthService AuthService
@inject NavigationManager Nav
@using CGym.Frontend.Services


<div class="aktiviteter-wrapper">
    <div class="page-header">
        <a href="/admin" class="back-btn">←</a>
        <h2 class="page-title">Aktiviteter</h2>
    </div>

    <p class="page-sub">Administrer centerets aktiviteter</p>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <p style="color:#dc2626; font-size:14px;">@loadError</p>
    }

    <div class="activity-list">
        @foreach (var activity in activities)
        {
            <div class="activity-card" style="border-top: 4px solid @activity.Color">
                <div class="activity-top">
                    <div>
                        <div class="activity-name">@activity.Name</div>
                        <div class="activity-instructor"><i class="ti ti-user"></i> @activity.Instructor</div>
                    </div>
                    <div class="activity-spots" style="color: @activity.Color">
                        @activity.SpotsLeft pladser
                    </div>
                </div>

                <div class="activity-info">
                    <span><i class="ti ti-calendar"></i> @activity.Date</span>
                    <span><i class="ti ti-clock"></i> @activity.Time</span>
                    <span><i class="ti ti-users"></i> @activity.Enrolled/@activity.Capacity</span>
                </div>

                @if (isEditing && editingId == activity.Id)
                {
                    <div class="edit-card">
                        <h3 class="edit-title">Rediger aktivitet</h3>

                        <div class="form-group">
                            <label>Aktivitetsnavn</label>
                            <input @bind="editName" class="input-field" />
                        </div>

                        <div class="form-group">
                            <label>Træner</label>
                            <select @bind="editTrainerId" class="input-field">
                                <option value="">Vælg en træner</option>
                                @foreach (var t in trainers)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Tidspunkt</label>
                            <input @bind="editStartTime" type="datetime-local" class="input-field" />
                        </div>

                        <div class="form-group">
                            <label>Kapacitet</label>
                            <input @bind="editCapacity" type="number" min="1" class="input-field" />
                        </div>

                        <button class="btn-save" type="button" @onclick="GemRedigering">Gem ændringer</button>
                    </div>
                }
                else
                {
                    <div class="admin-actions">
                        <button class="btn-edit" type="button" @onclick="() => StartRedigering(activity)">Rediger</button>
                        <button class="btn-delete" @onclick="() => SletAktivitet(activity)">Slet aktivitet</button>
                    </div>
                }

            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast @(showToast ? "show" : "")">
            <i class="ti @toastIcon"></i> @message
        </div>
    }
</div>

<style>
    .aktiviteter-wrapper {
        padding: 24px 16px;
        max-width: 800px;
        margin: 0 auto;
        font-family: 'Segoe UI', sans-serif;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 4px;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .back-btn {
        font-size: 20px;
        color: #111827;
        text-decoration: none;
    }

    .page-sub {
        color: #6b7280;
        font-size: 14px;
        margin: 0 0 20px 0;
    }

    .edit-card {
        background: white;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 16px;
    }

    .edit-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .form-group label {
            font-size: 14px;
            font-weight: 500;
            color: #374151;
        }

    .input-field {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 15px;
        outline: none;
        box-sizing: border-box;
    }

        .input-field:focus {
            border-color: #2563eb;
        }

    .btn-save {
        width: 100%;
        padding: 14px;
        background: #2563eb;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-save:hover {
            background: #1d4ed8;
        }


    .activity-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .activity-card {
        background: white;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .activity-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .activity-name {
        font-size: 17px;
        font-weight: 700;
        color: #111827;
    }

    .activity-instructor {
        font-size: 13px;
        color: #6b7280;
        margin-top: 4px;
    }

    .activity-spots {
        font-size: 13px;
        font-weight: 600;
    }

    .activity-info {
        display: flex;
        gap: 16px;
        font-size: 13px;
        color: #6b7280;
    }

    .admin-actions {
        display: flex;
        gap: 10px;
        margin-top: 6px;
    }

    .btn-edit,
    .btn-delete {
        flex: 1;
        padding: 14px;
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        color: white;
        transition: background 0.2s;
    }

    .btn-edit {
        background: #2563eb;
    }

        .btn-edit:hover {
            background: #1d4ed8;
        }

    .btn-delete {
        background: #dc2626;
    }

        .btn-delete:hover {
            background: #b91c1c;
        }

    .toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #111827;
        color: white;
        padding: 12px 24px;
        border-radius: 10px;
        font-size: 14px;
        opacity: 0;
        transition: all 0.3s;
        pointer-events: none;
    }

     toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
</style>

@code {
    private string message = "";
    private string toastIcon = "ti-alert-triangle";
    private bool showToast = false;
    private string? loadError;
    private List<ActivityItem> activities = new();
    private List<TrainerApiModel> trainers = new();
    private bool isEditing = false;
    private int editingId;
    private string editName = "";
    private int editCapacity = 0;
    private DateTime? editStartTime;
    private int? editTrainerId;


    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated || !AuthService.IsAdmin)
        {
            Nav.NavigateTo("/admin/login");
            return;
        }

        try
        {
            loadError = null;

            trainers = await TrainerService.GetTrainersAsync();
            var apiActivities = await ActivityService.GetActivitiesAsync();

            activities = apiActivities
                .Where(a => a.StartTime >= DateTime.Now)
                .Select(a => new ActivityItem(
                    a.Id,
                    a.Name,
                    a.Trainer?.Id ?? 0,
                    a.Trainer?.Name ?? "Ikke angivet",
                    a.StartTime.ToString("dd-MM-yyyy"),
                    a.StartTime.ToString("HH:mm"),
                    a.Capacity,
                    0,
                    "#16a34a"))
                .ToList();
        }
        catch (HttpRequestException)
        {
            loadError = "Kunne ikke hente aktiviteter lige nu.";
            activities = new();
            trainers = new();
        }
        catch
        {
            loadError = "Der skete en uventet fejl ved indlæsning af aktiviteter.";
            activities = new();
            trainers = new();
        }
    }


    private async Task SletAktivitet(ActivityItem activity)
    {
        try
        {
            await ActivityService.DeleteActivityAsync(activity.Id);
            activities.Remove(activity);

            toastIcon = "ti-circle-check";
            message = $"{activity.Name} er slettet.";
        }
        catch
        {
            toastIcon = "ti-alert-triangle";
            message = "Kunne ikke slette aktivitet lige nu.";
        }

        showToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        showToast = false;
        message = "";
        StateHasChanged();
    }

    private void StartRedigering(ActivityItem activity)
    {
        isEditing = true;
        editingId = activity.Id;
        editName = activity.Name;
        editCapacity = activity.Capacity;
        editTrainerId = activity.TrainerId;
        editStartTime = DateTime.ParseExact(
            $"{activity.Date} {activity.Time}",
            "dd-MM-yyyy HH:mm",
            System.Globalization.CultureInfo.InvariantCulture);
    }

    private async Task GemRedigering()
    {
        if (string.IsNullOrWhiteSpace(editName) ||
            !editStartTime.HasValue ||
            editCapacity <= 0 ||
            !editTrainerId.HasValue)
        {
            toastIcon = "ti-alert-triangle";
            message = "Udfyld alle felter korrekt.";
            showToast = true;
            return;
        }

        var request = new CreateActivityRequest
        {
            Name = editName.Trim(),
            StartTime = editStartTime.Value,
            Capacity = editCapacity,
            TrainerId = editTrainerId.Value
        };

        try
        {
            await ActivityService.UpdateActivityAsync(editingId, request);
            isEditing = false;

            // genindlæs listen, så UI viser nyeste data
            var apiActivities = await ActivityService.GetActivitiesAsync();
            activities = apiActivities
                .Where(a => a.StartTime >= DateTime.Now)
                .Select(a => new ActivityItem(
                    a.Id,
                    a.Name,
                    a.Trainer?.Id ?? 0,
                    a.Trainer?.Name ?? "Ikke angivet",
                    a.StartTime.ToString("dd-MM-yyyy"),
                    a.StartTime.ToString("HH:mm"),
                    a.Capacity,
                    0,
                    "#16a34a"))
                .ToList();

            toastIcon = "ti-circle-check";
            message = "Aktivitet opdateret.";
        }
        catch
        {
            toastIcon = "ti-alert-triangle";
            message = "Kunne ikke opdatere aktivitet lige nu.";
        }

        showToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        showToast = false;
        message = "";
        StateHasChanged();
    }



    private record ActivityItem(int Id, string Name, int TrainerId, string Instructor, string Date, string Time, int Capacity, int Enrolled, string Color)
    {
        public int SpotsLeft => Capacity - Enrolled;
    }
}

