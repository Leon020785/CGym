@page "/changePassword"
@inject CGym.Frontend.Services.AuthService Auth
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory

<div class="profile-wrapper">
    <div class="page-header">
        <a href="/profil" class="back-btn">←</a>
        <h2 class="page-title">Skift adgangskode</h2>
    </div>
    <p class="page-sub">Opdater din adgangskode herunder</p>

    <div class="profile-card">
        <div class="profile-top">
            <div>
                <div class="profile-kicker">Sikkerhed</div>
                <div class="profile-name">Adgangskode</div>
            </div>
        </div>

        <div class="profile-form">
            <div class="form-group full-width">
                <label for="currentPassword">Nuværende adgangskode</label>
                <input id="currentPassword" @bind="currentPassword" type="password" class="input-field" />
            </div>

            <div class="form-group">
                <label for="newPassword">Ny adgangskode</label>
                <input id="newPassword" @bind="newPassword" type="password" class="input-field" />
            </div>

            <div class="form-group">
                <label for="confirmPassword">Bekræft ny adgangskode</label>
                <input id="confirmPassword" @bind="confirmPassword" type="password" class="input-field" />
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="@(success ? "success-msg" : "error-msg")">@message</p>
        }

        <div class="profile-actions">
            <button type="button" class="btn-profile-primary" @onclick="HandleSubmit" disabled="@isSaving">
                @(isSaving ? "Gemmer..." : "Gem adgangskode")
            </button>
            <button type="button" class="btn-profile-outline" @onclick="Cancel" disabled="@isSaving">
                Annuller
            </button>
        </div>
    </div>
</div>

<style>
    .profile-wrapper {
        padding: 24px 16px;
        max-width: 800px;
        margin: 0 auto;
        font-family: 'Segoe UI', sans-serif;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 4px;
    }

    .back-btn {
        font-size: 20px;
        color: #111827;
        text-decoration: none;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .page-sub {
        color: #6b7280;
        font-size: 14px;
        margin: 0 0 20px 0;
    }

    .profile-card {
        background: white;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .profile-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
    }

    .profile-kicker {
        color: #16a34a;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .profile-name {
        font-size: 20px;
        font-weight: 700;
        color: #111827;
    }

    .profile-form {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .form-group label {
            color: #374151;
            font-size: 14px;
            font-weight: 600;
        }

    .full-width {
        grid-column: 1 / -1;
    }

    .input-field {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        color: #111827;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

        .input-field:focus {
            border-color: #16a34a;
        }

    .profile-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .btn-profile-primary {
        background: #16a34a;
        color: white;
        padding: 12px 24px;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-profile-primary:hover {
            background: #15803d;
            color: white;
        }

        .btn-profile-primary:disabled {
            background: #86efac;
            cursor: not-allowed;
        }

    .btn-profile-outline {
        background: white;
        color: #111827;
        padding: 12px 24px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s;
    }

        .btn-profile-outline:hover {
            border-color: #16a34a;
            color: #16a34a;
        }

        .btn-profile-outline:disabled {
            color: #9ca3af;
            cursor: not-allowed;
        }

    .error-msg {
        color: #dc2626;
        font-size: 14px;
        margin: 0;
    }

    .success-msg {
        color: #16a34a;
        font-size: 14px;
        margin: 0;
    }

    @@media (max-width: 640px) {
        .profile-form,
        .profile-actions {
            grid-template-columns: 1fr;
        }

        .full-width {
            grid-column: 1;
        }

        .btn-profile-primary,
        .btn-profile-outline {
            width: 100%;
        }
    }
</style>

@code {
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string message = "";
    private bool success;
    private bool isSaving;

    protected override void OnInitialized()
    {
        if (!Auth.IsAuthenticated)
            Nav.NavigateTo("/login");
    }

    private async Task HandleSubmit()
    {
        message = "";

        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(confirmPassword))
        {
            success = false;
            message = "Alle felter skal udfyldes.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            success = false;
            message = "Den nye adgangskode og bekræftelsen stemmer ikke overens.";
            return;
        }

        isSaving = true;

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Auth.Token);

            var response = await http.PostAsJsonAsync("api/auth/change-password", new
            {
                currentPassword,
                newPassword
            });

            if (response.IsSuccessStatusCode)
            {
                success = true;
                message = "Adgangskode er ændret.";
                Reset();
            }
            else
            {
                success = false;
                message = "Nuværende adgangskode er forkert.";
            }
        }
        catch
        {
            success = false;
            message = "Noget gik galt. Prøv igen.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Reset()
    {
        currentPassword = "";
        newPassword = "";
        confirmPassword = "";
    }

    private void Cancel()
    {
        Nav.NavigateTo(Auth.IsAdmin ? "/admin" : "/");
    }
}
