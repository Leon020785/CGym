@page "/admin/register"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<div class="login-wrapper">
    <div class="login-card">
        <div class="logo-icon">
            <i class="ti ti-shield-lock" style="font-size:40px; color:white;"></i>
        </div>

        <h1 class="brand">Admin Registrering</h1>
        <p class="subtitle">Opret en ny admin konto</p>

        <div class="form-group">
            <label>Email</label>
            <input @bind="email" type="email" placeholder="admin@eksempel.dk" class="input-field" />
        </div>

        <div class="form-group">
            <label>Adgangskode</label>
            <div class="password-wrapper">
                <input @bind="password" @bind:event="oninput" type="@(showPassword ? "text" : "password")" placeholder="••••••••" class="input-field password-input" />
                <button type="button" class="eye-toggle" @onclick="() => showPassword = !showPassword" tabindex="-1">
                    @if (showPassword)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                            <line x1="1" y1="1" x2="23" y2="23" />
                        </svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    }
                </button>
            </div>
            <ul class="pwd-rules">
                <li class="@(RuleLength ? "rule-ok" : "rule-fail")">@(RuleLength ? "✓" : "✗") Minimum 8 tegn</li>
                <li class="@(RuleUpper ? "rule-ok" : "rule-fail")">@(RuleUpper ? "✓" : "✗") Mindst ét stort bogstav</li>
                <li class="@(RuleDigit ? "rule-ok" : "rule-fail")">@(RuleDigit ? "✓" : "✗") Mindst ét tal</li>
            </ul>
        </div>

        <div class="form-group">
            <label>Bekræft adgangskode</label>
            <div class="password-wrapper">
                <input @bind="confirmPassword" type="@(showConfirmPassword ? "text" : "password")" placeholder="••••••••" class="input-field password-input" />
                <button type="button" class="eye-toggle" @onclick="() => showConfirmPassword = !showConfirmPassword" tabindex="-1">
                    @if (showConfirmPassword)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                            <line x1="1" y1="1" x2="23" y2="23" />
                        </svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    }
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <p class="@(success ? "success-msg" : "error-msg")">@message</p>
        }

        <button @onclick="HandleRegister" class="btn-login" disabled="@isLoading">
            @if (isLoading)
            {
                <span>Opretter konto...</span>
            }
            else
            {
                <span>Opret admin konto</span>
            }
        </button>

        <p class="register-link">
            Har du allerede en konto? <a href="/admin/login">Log ind</a>
        </p>
    </div>
</div>

<style>
    .login-wrapper {
        height: calc(100vh - 60px);
        overflow: hidden;
        width: 100%;
        background: linear-gradient(135deg, #1e3a5f 0%, #1e40af 50%, #1d4ed8 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .login-card {
        background: white;
        border-radius: 20px;
        padding: clamp(16px, 3vh, 48px) clamp(16px, 3vw, 40px);
        width: 90%;
        max-width: 420px;
        max-height: 95vh;
        margin: 16px 0;
        box-shadow: 0 8px 40px rgba(0,0,0,0.20);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: clamp(2px, 0.5vh, 4px);
    }

    .logo-icon {
        background: #1d4ed8;
        border-radius: 16px;
        width: 55px;
        height: 55px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 4px;
    }

    .brand {
        font-size: 1.4rem;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .subtitle {
        color: #6b7280;
        font-size: 0.85rem;
        margin: 0;
    }

    .form-group {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 6px;
    }

        .form-group label {
            font-size: 14px;
            font-weight: 500;
            color: #374151;
        }

    .input-field {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

        .input-field:focus {
            border-color: #1d4ed8;
        }

    .btn-login {
        width: 100%;
        padding: 12px;
        background: #1d4ed8;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.2s;
    }

        .btn-login:hover {
            background: #1e40af;
        }

        .btn-login:disabled {
            background: #93c5fd;
            cursor: not-allowed;
        }

    .error-msg {
        color: #dc2626;
        font-size: 14px;
        margin: 0;
    }

    .success-msg {
        color: #16a34a;
        font-size: 14px;
        margin: 0;
    }

    .register-link {
        font-size: 14px;
        color: #6b7280;
        margin-top: 8px;
    }

        .register-link a {
            color: #1d4ed8;
            font-weight: 600;
            text-decoration: none;
        }

            .register-link a:hover {
                text-decoration: underline;
            }

    .password-wrapper {
        position: relative;
        width: 100%;
    }

    .password-input {
        padding-right: 44px;
    }

    .eye-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        color: #6b7280;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
    }

        .eye-toggle:hover {
            color: #374151;
        }

    .pwd-rules {
        list-style: none;
        padding: 6px 0 0 0;
        margin: 2px 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

        .pwd-rules li {
            font-size: 11px;
        }

    .rule-ok {
        color: #16a34a;
    }

    .rule-fail {
        color: #9ca3af;
    }

    @@media (max-width: 480px) {
        .login-card {
            padding: 24px 16px;
        }
    }
</style>

@code {
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private string message = "";
    private bool isLoading = false;
    private bool success = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;

    private bool RuleLength => password.Length >= 8;
    private bool RuleUpper => password.Any(char.IsUpper);
    private bool RuleDigit => password.Any(char.IsDigit);

    private async Task HandleRegister()
    {
        isLoading = true;
        message = "";

        if (!email.Contains('@'))
        {
            message = "Indtast en gyldig email.";
            isLoading = false;
            return;
        }

        if (!RuleLength || !RuleUpper || !RuleDigit)
        {
            message = "Adgangskoden opfylder ikke kravene.";
            isLoading = false;
            return;
        }

        if (password != confirmPassword)
        {
            message = "Adgangskoderne stemmer ikke overens.";
            isLoading = false;
            return;
        }

        var username = email.Split('@')[0];
        var http = HttpClientFactory.CreateClient("API");

        var response = await http.PostAsJsonAsync("api/auth/admin/register", new
        {
            username,
            email,
            password
        });

        if (response.IsSuccessStatusCode)
        {
            success = true;
            message = "Admin oprettet! Du sendes til login...";
            await Task.Delay(1500);
            Nav.NavigateTo("/admin/login");
        }
        else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            success = false;
            message = "Emailen er allerede i brug.";
        }
        else
        {
            success = false;
            message = "Noget gik galt. Prøv igen.";
        }

        isLoading = false;
    }
}
