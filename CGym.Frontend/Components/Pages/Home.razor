        }

        .stat-card.white {
            background: white;
            border: 1.5px solid #e5e7eb;
            color: #111827;
        }

    .stat-icon {
        font-size: 20px;
    }

    .stat-number {
        font-size: 32px;
        font-weight: 700;
    }

    .stat-label {
        font-size: 13px;
        opacity: 0.85;
    }

    .champion-banner {
        background: linear-gradient(90deg, #f59e0b 0%, #f97316 100%);
        border-radius: 14px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        color: white;
    }

    .champion-icon {
        font-size: 28px;
    }

    .champion-title {
        font-weight: 700;
        font-size: 16px;
    }

    .champion-sub {
        font-size: 13px;
        opacity: 0.9;
    }

    .btn-full-green {
        display: block;
        text-align: center;
        background: #16a34a;
        color: white;
        padding: 16px;
        border-radius: 12px;
