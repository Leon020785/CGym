    .quote {
        color: white;
        font-size: 16px;
        font-weight: 600;
        margin: 0 0 6px 0;
        text-shadow: 0 2px 8px rgba(0,0,0,0.85);
    }

    .hero-link {
        color: #86efac;
        font-size: 14px;
        font-weight: 700;
        text-shadow: 0 2px 8px rgba(0,0,0,0.85);
    }


    .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
