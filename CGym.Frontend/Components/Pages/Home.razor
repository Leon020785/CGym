        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        border: 2px solid #16a34a;
    }
</style>

@code {
    private int aktiveBookinger = 0;
    private int holdTilgaengelige = 0;
    private int holdDenneMaaned = 0;
    private int totalTraeningsdage = 0;
    private string favoritAktivitet = "Ingen endnu";
    private int ugensHold = 0;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Auth.Token))
        {
            Nav.NavigateTo("/login");
            return;
        }

        var bookinger = await BookingService.GetBookingsAsync();
        aktiveBookinger = bookinger.Count;
        totalTraeningsdage = bookinger.Count;

        var nu = DateTime.Now;
        holdDenneMaaned = bookinger.Count(b =>
            b.Activity?.StartTime.Month == nu.Month &&
            b.Activity?.StartTime.Year == nu.Year);

        ugensHold = bookinger.Count(b =>
            b.Activity?.StartTime >= nu.AddDays(-(int)nu.DayOfWeek) &&
            b.Activity?.StartTime <= nu);

        var favorit = bookinger
            .GroupBy(b => b.Activity?.Name)
            .OrderByDescending(g => g.Count())
            .FirstOrDefault();
        favoritAktivitet = favorit?.Key ?? "Ingen endnu";

        var aktiviteter = await ActivityService.GetActivitiesAsync();
        holdTilgaengelige = aktiviteter.Count;
    }
}