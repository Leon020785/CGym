        color: #111827;
        margin: 0;
    }

    .welcome-sub {
        color: #6b7280;
        margin: 4px 0 0 0;
        font-size: 15px;
    }

    .hero-banner {
        background-image: url("https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=1200&q=80");
        background-size: cover;
        background-position: center 60%;
        background-repeat: no-repeat;
        border-radius: 16px;
        padding: 32px 24px;
        min-height: 200px;
